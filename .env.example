# ============================================================================
# LabGenie Provider Configuration
#
# LabGenie auto-detects which provider to use based on what's configured.
# Priority: claude-code (subscription) > claude (API) > vertex > gemini
#
# Optional: Force a specific provider
# LABGENIE_PROVIDER=claude-code   # Claude Code subscription (default)
# LABGENIE_PROVIDER=claude        # Anthropic API
# LABGENIE_PROVIDER=gemini        # Google Gemini API
# LABGENIE_PROVIDER=vertex        # Google Cloud Vertex AI
# ============================================================================

# ----------------------------------------------------------------------------
# Option 1: Claude Code subscription (Recommended — no API costs)
# ----------------------------------------------------------------------------
# Install Claude Code from https://claude.ai/download then run: claude login
# No environment variables needed — LabGenie detects the CLI automatically.

# ----------------------------------------------------------------------------
# Option 2: Claude API (pay-per-use via console.anthropic.com)
# ----------------------------------------------------------------------------
# NOTE: This is a separate API key from your Claude.ai subscription.
#       Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# ----------------------------------------------------------------------------
# Option 3: Gemini API
# ----------------------------------------------------------------------------
# Get your key: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key

# ----------------------------------------------------------------------------
# Option 4: Vertex AI (Enterprise)
# ----------------------------------------------------------------------------
# REQUIRED: Your GCP Project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# OPTIONAL: Vertex AI region (default: us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# OPTIONAL: Path to service account key file (if not using ADC)
# Not needed if you've run: gcloud auth application-default login
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# See README.md for full setup instructions
